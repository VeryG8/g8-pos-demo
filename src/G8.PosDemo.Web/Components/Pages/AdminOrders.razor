@page "/admin/orders"
@using System.Globalization
@using G8.PosDemo.Web.Data
@using Microsoft.EntityFrameworkCore
@inject PosDbContext Db

<PageTitle>訂單管理</PageTitle>

@code {
    private readonly List<OrderRow> _orders = [];
    private string _filter = "All";
    private string _status = "讀取訂單中...";
    private DateTime _fromDate = DateTime.Today;
    private DateTime _toDate = DateTime.Today;
    private OrderDetailViewModel? _selectedOrder;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var fromLocal = _fromDate.Date;
        var toLocalExclusive = _toDate.Date.AddDays(1);
        var fromUtc = fromLocal.ToUniversalTime();
        var toUtc = toLocalExclusive.ToUniversalTime();

        var query = Db.Orders
            .AsNoTracking()
            .Where(x => x.CreatedAt >= fromUtc && x.CreatedAt < toUtc)
            .OrderByDescending(x => x.CreatedAt)
            .AsQueryable();

        if (_filter != "All")
        {
            query = query.Where(x => x.Status == _filter);
        }

        var rows = await query
            .Select(x => new OrderRow(x.Id, x.OrderCode, x.CreatedAt, x.PaymentMethod, x.TotalAmount, x.Status))
            .ToListAsync();

        _orders.Clear();
        _orders.AddRange(rows);
        _status = $"已載入 {_orders.Count} 筆訂單。";

        if (_selectedOrder is not null)
        {
            var selected = _orders.FirstOrDefault(x => x.Id == _selectedOrder.Id);
            if (selected is not null)
            {
                await ShowDetailAsync(selected);
            }
        }
    }

    private async Task SetFilterAsync(string filter)
    {
        _filter = filter;
        await LoadAsync();
    }

    private async Task ShowDetailAsync(OrderRow row)
    {
        var order = await Db.Orders
            .AsNoTracking()
            .Include(x => x.Items)
            .FirstAsync(x => x.Id == row.Id);

        _selectedOrder = new OrderDetailViewModel(
            order.Id,
            order.OrderCode,
            order.CreatedAt.ToLocalTime(),
            order.PaymentMethod,
            ToChineseStatus(order.Status),
            order.TotalAmount,
            order.CustomerPhone,
            order.Items.Select(x => new OrderItemDetailViewModel(
                x.ProductName,
                x.Size,
                x.Sugar,
                x.Ice,
                x.Toppings ?? "無加料",
                x.Note,
                x.Quantity,
                x.UnitPrice)).ToList());
    }

    private static string ToChineseStatus(string status) => status switch
    {
        "Draft" => "暫存",
        "Completed" => "完成",
        "Voided" => "作廢",
        _ => status
    };

    private sealed record OrderRow(int Id, string OrderCode, DateTime CreatedAt, string Payment, decimal Amount, string Status);
    private sealed record OrderDetailViewModel(int Id, string OrderCode, DateTime CreatedAt, string Payment, string Status, decimal Amount, string? CustomerPhone, List<OrderItemDetailViewModel> Items);
    private sealed record OrderItemDetailViewModel(string ProductName, string Size, string Sugar, string Ice, string Toppings, string? Note, int Quantity, decimal UnitPrice);
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="eyebrow">Admin / Orders</div>
            <h1>訂單管理</h1>
        </div>
        <div class="admin-status">@_status</div>
    </div>

    <div class="orders-page-grid">
        <div class="admin-card form-card">
            <div class="payment-row">
                <button class="option-chip compact @(_filter == "All" ? "active" : null)" @onclick='() => SetFilterAsync("All")'>全部</button>
                <button class="option-chip compact @(_filter == "Draft" ? "active" : null)" @onclick='() => SetFilterAsync("Draft")'>暫存</button>
                <button class="option-chip compact @(_filter == "Completed" ? "active" : null)" @onclick='() => SetFilterAsync("Completed")'>完成</button>
                <button class="option-chip compact @(_filter == "Voided" ? "active" : null)" @onclick='() => SetFilterAsync("Voided")'>作廢</button>
            </div>

            <label>開始日期</label>
            <input class="admin-input" type="date" @bind="_fromDate" />

            <label>結束日期</label>
            <input class="admin-input" type="date" @bind="_toDate" />

            <button class="primary-action" @onclick="LoadAsync">套用日期篩選</button>
        </div>

        <div class="admin-card order-list-card">
            <div class="admin-table-header order-grid-header clickable-order-grid">
                <strong>訂單號</strong>
                <strong>時間</strong>
                <strong>付款</strong>
                <strong>狀態</strong>
                <strong>金額</strong>
            </div>

            <div class="order-list-scroll">
                @foreach (var order in _orders)
                {
                    <button class="admin-table-row clickable-order-row clickable-order-grid @(_selectedOrder?.Id == order.Id ? "selected-order-row" : null)" @onclick="() => ShowDetailAsync(order)">
                        <strong>@order.OrderCode</strong>
                        <span>@order.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span>@order.Payment</span>
                        <span>@ToChineseStatus(order.Status)</span>
                        <strong>@order.Amount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                    </button>
                }
            </div>
        </div>

        <div class="admin-card detail-card right-detail-card">
            @if (_selectedOrder is null)
            {
                <div class="empty-state small-fill">點左側任一筆訂單，右側會顯示明細。</div>
            }
            else
            {
                <div class="section-header compact">
                    <h2>訂單明細：@_selectedOrder.OrderCode</h2>
                </div>

                <div class="report-grid detail-top-grid">
                    <div class="report-panel">
                        <span>時間</span>
                        <strong>@_selectedOrder.CreatedAt.ToString("yyyy/MM/dd HH:mm")</strong>
                    </div>
                    <div class="report-panel">
                        <span>付款方式</span>
                        <strong>@_selectedOrder.Payment</strong>
                    </div>
                    <div class="report-panel">
                        <span>狀態 / 總額</span>
                        <strong>@_selectedOrder.Status / @_selectedOrder.Amount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                        <small>會員：@(_selectedOrder.CustomerPhone ?? "未填")</small>
                    </div>
                </div>

                <div class="admin-table-header detail-item-grid">
                    <strong>商品</strong>
                    <strong>規格</strong>
                    <strong>備註</strong>
                    <strong>數量</strong>
                    <strong>單價</strong>
                </div>

                <div class="order-list-scroll">
                    @foreach (var item in _selectedOrder.Items)
                    {
                        <div class="admin-table-row detail-item-grid">
                            <strong>@item.ProductName</strong>
                            <span>@item.Size / @item.Sugar / @item.Ice / @item.Toppings</span>
                            <span>@(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)</span>
                            <span>@item.Quantity</span>
                            <strong>@item.UnitPrice.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
