@page "/admin/reports"
@using System.Globalization

<PageTitle>營業報表</PageTitle>

@code {
    private readonly List<ReportBlock> _blocks =
    [
        new("本日營業額", 4280m, "較昨日 +12%"),
        new("今日訂單數", 67m, "平均客單 63 元"),
        new("人氣商品", 18m, "珍珠奶茶 18 杯")
    ];

    private sealed record ReportBlock(string Title, decimal Value, string Note);
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="eyebrow">Admin / Reports</div>
            <h1>營業報表</h1>
        </div>
    </div>

    <div class="report-grid">
        @foreach (var block in _blocks)
        {
            <div class="report-panel">
                <span>@block.Title</span>
                <strong>@(block.Title == "本日營業額" ? block.Value.ToString("C0", CultureInfo.GetCultureInfo("zh-TW")) : block.Value.ToString("0"))</strong>
                <small>@block.Note</small>
            </div>
        }
    </div>
</div>
