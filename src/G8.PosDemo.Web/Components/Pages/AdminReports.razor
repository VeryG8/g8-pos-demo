@page "/admin/reports"
@using System.Globalization
@using G8.PosDemo.Web.Data
@using Microsoft.EntityFrameworkCore
@inject PosDbContext Db

<PageTitle>營業報表</PageTitle>

@code {
    private decimal _dailyRevenue;
    private int _orderCount;
    private string _topProduct = "尚無資料";
    private decimal _promotionDiscountTotal;
    private int _takeoutCount;
    private int _deliveryCount;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.UtcNow.Date;
        var tomorrow = today.AddDays(1);

        var orders = await Db.Orders
            .AsNoTracking()
            .Where(x => x.CreatedAt >= today && x.CreatedAt < tomorrow)
            .ToListAsync();

        _dailyRevenue = orders.Sum(x => x.TotalAmount);
        _orderCount = orders.Count;
        _promotionDiscountTotal = orders.Sum(x => x.PromotionDiscountAmount);
        _takeoutCount = orders.Count(x => x.OrderType == "Takeout");
        _deliveryCount = orders.Count(x => x.OrderType == "Delivery");

        var topItem = await Db.OrderItems
            .AsNoTracking()
            .GroupBy(x => x.ProductName)
            .Select(g => new { ProductName = g.Key, Qty = g.Sum(x => x.Quantity) })
            .OrderByDescending(x => x.Qty)
            .FirstOrDefaultAsync();

        _topProduct = topItem is null ? "尚無資料" : $"{topItem.ProductName} / {topItem.Qty} 杯";
    }
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="eyebrow">Admin / Reports</div>
            <h1>營業報表</h1>
        </div>
    </div>

    <div class="report-grid">
        <div class="report-panel">
            <span>本日營業額</span>
            <strong>@_dailyRevenue.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
            <small>由資料庫訂單計算</small>
        </div>

        <div class="report-panel">
            <span>今日訂單數</span>
            <strong>@_orderCount</strong>
            <small>今日已完成訂單</small>
        </div>

        <div class="report-panel">
            <span>人氣商品</span>
            <strong>@_topProduct</strong>
            <small>依歷史訂單項目統計</small>
        </div>

        <div class="report-panel">
            <span>今日優惠折抵</span>
            <strong>@_promotionDiscountTotal.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
            <small>活動總折扣</small>
        </div>

        <div class="report-panel">
            <span>外帶訂單</span>
            <strong>@_takeoutCount</strong>
            <small>外帶筆數</small>
        </div>

        <div class="report-panel">
            <span>外送訂單</span>
            <strong>@_deliveryCount</strong>
            <small>外送筆數</small>
        </div>
    </div>
</div>
