@page "/admin/products"
@using System.Globalization
@using G8.PosDemo.Web.Data
@using Microsoft.EntityFrameworkCore
@inject PosDbContext Db

<PageTitle>商品管理</PageTitle>

@code {
    private readonly List<ProductRow> _products = [];
    private string _status = "讀取商品中...";

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        var rows = await Db.Products
            .AsNoTracking()
            .Include(x => x.Category)
            .OrderBy(x => x.CategoryId)
            .ThenBy(x => x.Name)
            .Select(x => new ProductRow(x.Id, x.Category!.Name, x.Name, x.BasePrice, x.IsEnabled))
            .ToListAsync();

        _products.Clear();
        _products.AddRange(rows);
        _status = $"已從資料庫載入 {_products.Count} 筆商品。";
    }

    private async Task ToggleAsync(ProductRow row)
    {
        var entity = await Db.Products.FirstAsync(x => x.Id == row.Id);
        entity.IsEnabled = !entity.IsEnabled;
        await Db.SaveChangesAsync();
        await LoadProductsAsync();
        _status = $"已更新商品狀態：{row.Name}";
    }

    private sealed record ProductRow(int Id, string Category, string Name, decimal Price, bool Enabled);
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="eyebrow">Admin / Products</div>
            <h1>商品管理</h1>
        </div>
        <div class="admin-status">@_status</div>
    </div>

    <div class="admin-card">
        <div class="admin-table-header">
            <strong>分類</strong>
            <strong>商品</strong>
            <strong>售價</strong>
            <strong>狀態</strong>
        </div>

        @foreach (var row in _products)
        {
            <div class="admin-table-row">
                <span>@row.Category</span>
                <strong>@row.Name</strong>
                <span>@row.Price.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</span>
                <button class="mini-action @(row.Enabled ? "enabled" : "disabled")" @onclick="() => ToggleAsync(row)">
                    @(row.Enabled ? "上架中" : "已下架")
                </button>
            </div>
        }
    </div>
</div>
