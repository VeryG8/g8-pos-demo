@page "/admin/promotions"
@using G8.PosDemo.Web.Data
@using G8.PosDemo.Web.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject PosDbContext Db

<PageTitle>優惠活動</PageTitle>

@code {
    private readonly List<PromotionRow> _promotions = [];
    private PromotionFormModel _form = new();
    private string _status = "讀取活動中...";
    private bool _isEditMode;
    private int? _editingId;

    protected override async Task OnInitializedAsync()
    {
        await LoadPromotionsAsync();
    }

    private async Task LoadPromotionsAsync()
    {
        var rows = await Db.Promotions
            .AsNoTracking()
            .OrderBy(x => x.SortOrder)
            .ThenBy(x => x.Id)
            .Select(x => new PromotionRow(x.Id, x.Name, x.OrderTypeScope, x.BuyQuantity, x.FreeQuantity, x.IsEnabled))
            .ToListAsync();

        _promotions.Clear();
        _promotions.AddRange(rows);
        _status = $"已載入 {_promotions.Count} 筆活動。";
    }

    private async Task ToggleAsync(PromotionRow row)
    {
        var entity = await Db.Promotions.FirstAsync(x => x.Id == row.Id);
        entity.IsEnabled = !entity.IsEnabled;
        await Db.SaveChangesAsync();
        await LoadPromotionsAsync();
        _status = $"已更新活動狀態：{row.Name}";
    }

    private void Edit(PromotionRow row)
    {
        _isEditMode = true;
        _editingId = row.Id;
        _form = new PromotionFormModel
        {
            Name = row.Name,
            OrderTypeScope = row.OrderTypeScope,
            BuyQuantity = row.BuyQuantity,
            FreeQuantity = row.FreeQuantity,
            IsEnabled = row.IsEnabled
        };
        _status = $"正在編輯：{row.Name}";
    }

    private void ResetForm()
    {
        _isEditMode = false;
        _editingId = null;
        _form = new PromotionFormModel();
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.BuyQuantity <= 0 || _form.FreeQuantity <= 0)
        {
            _status = "請先填寫完整活動資訊。";
            return;
        }

        if (_isEditMode && _editingId.HasValue)
        {
            var entity = await Db.Promotions.FirstAsync(x => x.Id == _editingId.Value);
            entity.Name = _form.Name.Trim();
            entity.OrderTypeScope = _form.OrderTypeScope;
            entity.BuyQuantity = _form.BuyQuantity;
            entity.FreeQuantity = _form.FreeQuantity;
            entity.IsEnabled = _form.IsEnabled;
            _status = $"已更新活動：{entity.Name}";
        }
        else
        {
            var nextSort = await Db.Promotions.Select(x => (int?)x.SortOrder).MaxAsync() ?? 0;
            var entity = new PromotionEntity
            {
                Name = _form.Name.Trim(),
                PromotionType = "BuyXGetY",
                OrderTypeScope = _form.OrderTypeScope,
                BuyQuantity = _form.BuyQuantity,
                FreeQuantity = _form.FreeQuantity,
                IsEnabled = _form.IsEnabled,
                SortOrder = nextSort + 1
            };
            Db.Promotions.Add(entity);
            _status = $"已新增活動：{entity.Name}";
        }

        await Db.SaveChangesAsync();
        await LoadPromotionsAsync();
        ResetForm();
    }

    private sealed record PromotionRow(int Id, string Name, string OrderTypeScope, int BuyQuantity, int FreeQuantity, bool IsEnabled);

    private sealed class PromotionFormModel
    {
        public string Name { get; set; } = "外帶買五送一";
        public string OrderTypeScope { get; set; } = "Takeout";
        public int BuyQuantity { get; set; } = 5;
        public int FreeQuantity { get; set; } = 1;
        public bool IsEnabled { get; set; } = true;
    }
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="eyebrow">Admin / Promotions</div>
            <h1>優惠活動</h1>
        </div>
        <div class="admin-status">@_status</div>
    </div>

    <div class="admin-layout-grid">
        <div class="admin-card form-card">
            <div class="section-header compact">
                <h2>@(_isEditMode ? "編輯活動" : "新增活動")</h2>
                @if (_isEditMode)
                {
                    <button class="ghost-action" @onclick="ResetForm">取消編輯</button>
                }
            </div>

            <label>活動名稱</label>
            <input class="admin-input" @bind="_form.Name" />

            <label>適用訂單類型</label>
            <select class="admin-input" @bind="_form.OrderTypeScope">
                <option value="Takeout">外帶</option>
                <option value="Delivery">外送</option>
                <option value="All">全部</option>
            </select>

            <label>買幾杯</label>
            <input class="admin-input" type="number" min="1" @bind="_form.BuyQuantity" />

            <label>送幾杯</label>
            <input class="admin-input" type="number" min="1" @bind="_form.FreeQuantity" />

            <label><input type="checkbox" @bind="_form.IsEnabled" /> 啟用中</label>

            <button class="primary-action" @onclick="SaveAsync">@(_isEditMode ? "儲存修改" : "新增活動")</button>
        </div>

        <div class="admin-card">
            <div class="admin-table-header">
                <strong>活動</strong>
                <strong>適用</strong>
                <strong>規則</strong>
                <strong>動作</strong>
            </div>

            @foreach (var row in _promotions)
            {
                <div class="admin-table-row">
                    <strong>@row.Name</strong>
                    <span>@(row.OrderTypeScope == "Takeout" ? "外帶" : row.OrderTypeScope == "Delivery" ? "外送" : "全部")</span>
                    <span>買 @row.BuyQuantity 送 @row.FreeQuantity</span>
                    <div class="admin-action-row">
                        <button class="ghost-action" @onclick="() => Edit(row)">編輯</button>
                        <button class="mini-action @(row.IsEnabled ? "enabled" : "disabled")" @onclick="() => ToggleAsync(row)">
                            @(row.IsEnabled ? "啟用中" : "已停用")
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
