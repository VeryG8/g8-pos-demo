@page "/"
@using System.Globalization
@using G8.PosDemo.Web.Data
@using G8.PosDemo.Web.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject PosDbContext Db

<PageTitle>G8 POS Demo</PageTitle>

@code {
    private readonly List<string> _sugarOptions = ["正常糖", "少糖", "半糖", "微糖", "無糖"];
    private readonly List<string> _iceOptions = ["正常冰", "少冰", "微冰", "去冰", "熱"];
    private readonly List<string> _paymentOptions = ["現金", "Line Pay", "街口", "信用卡"];
    private readonly List<string> _orderTypeOptions = ["外帶", "外送"];
    private readonly List<OrderLine> _cart = [];
    private readonly List<CompletedOrder> _recentOrders = [];
    private readonly List<ProductCategoryViewModel> _categories = [];
    private readonly List<PromotionViewModel> _promotions = [];

    private ProductCategoryViewModel? _selectedCategory;
    private ProductViewModel? _selectedProduct;
    private string _selectedSize = "M";
    private string _selectedSugar = "半糖";
    private string _selectedIce = "少冰";
    private bool _addPearl;
    private bool _addCoconut;
    private string _selectedPayment = "現金";
    private string _selectedOrderType = "外帶";
    private string _customerPhone = string.Empty;
    private string _note = string.Empty;
    private decimal _discountAmount;
    private decimal _receivedAmount;
    private bool _showCheckoutConfirm;
    private string _status = "待點餐";
    private string _searchText = string.Empty;
    private int _nextOrderNumber = 1001;
    private string _currentOrderCode = "A1001";
    private int? _editingDraftOrderId;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
        await LoadPromotionsAsync();
        await LoadRecentOrdersAsync();
    }

    private async Task LoadProductsAsync()
    {
        var categories = await Db.ProductCategories
            .AsNoTracking()
            .Include(x => x.Products)
            .OrderBy(x => x.SortOrder)
            .ToListAsync();

        _categories.Clear();
        _categories.AddRange(categories.Select(category => new ProductCategoryViewModel(
            category.Id,
            category.Name,
            category.Products
                .Where(p => p.IsEnabled)
                .OrderBy(p => p.Name)
                .Select(product => new ProductViewModel(
                    product.Id,
                    product.Name,
                    product.BasePrice,
                    product.SizeOptions.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList(),
                    product.IsTea))
                .ToList())));

        _selectedCategory ??= _categories.FirstOrDefault();
        _status = _categories.Count == 0 ? "目前沒有上架商品。" : "商品已從資料庫載入。";
    }

    private async Task LoadPromotionsAsync()
    {
        var promotions = await Db.Promotions
            .AsNoTracking()
            .Where(x => x.IsEnabled)
            .OrderBy(x => x.SortOrder)
            .ThenBy(x => x.Id)
            .Select(x => new PromotionViewModel(x.Id, x.Name, x.OrderTypeScope, x.BuyQuantity, x.FreeQuantity, x.IsEnabled))
            .ToListAsync();

        _promotions.Clear();
        _promotions.AddRange(promotions);
    }

    private async Task LoadRecentOrdersAsync()
    {
        var orders = await Db.Orders
            .AsNoTracking()
            .OrderByDescending(x => x.CreatedAt)
            .Take(6)
            .ToListAsync();

        _recentOrders.Clear();
        _recentOrders.AddRange(orders.Select(x => new CompletedOrder(
            x.Id,
            x.OrderCode,
            x.CreatedAt.ToLocalTime(),
            x.PaymentMethod,
            x.OrderSummary ?? string.Empty,
            x.TotalAmount,
            x.Status,
            x.OrderType,
            x.PromotionName,
            x.PromotionDiscountAmount)));

        var latestCode = orders
            .Select(x => x.OrderCode)
            .Where(x => x.StartsWith("A") && int.TryParse(x[1..], out _))
            .Select(x => int.Parse(x[1..]))
            .DefaultIfEmpty(1000)
            .Max();

        _nextOrderNumber = latestCode + 1;
        _currentOrderCode = $"A{_nextOrderNumber}";
    }

    private void SelectCategory(ProductCategoryViewModel category)
    {
        _selectedCategory = category;
        _selectedProduct = null;
    }

    private void SelectProduct(ProductViewModel product)
    {
        _selectedProduct = product;
        _selectedSize = product.Sizes.First();
        _selectedSugar = product.IsTea ? "微糖" : "半糖";
        _selectedIce = product.IsTea ? "少冰" : "正常冰";
        _addPearl = false;
        _addCoconut = false;
    }

    private IEnumerable<ProductViewModel> FilteredProducts =>
        (_selectedCategory?.Products ?? [])
            .Where(p => string.IsNullOrWhiteSpace(_searchText) || p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    private PromotionViewModel? ActivePromotion =>
        _promotions.FirstOrDefault(x =>
            x.IsEnabled &&
            (x.OrderTypeScope == "All" || x.OrderTypeScope == SelectedOrderTypeCode));

    private string SelectedOrderTypeCode => _selectedOrderType == "外帶" ? "Takeout" : "Delivery";

    private decimal CurrentSelectedPrice
    {
        get
        {
            if (_selectedProduct is null)
            {
                return 0m;
            }

            var sizeExtra = _selectedSize == "L" && _selectedProduct.Sizes.Count > 1 ? 5m : 0m;
            var toppingExtra = (_addPearl ? 10m : 0m) + (_addCoconut ? 10m : 0m);
            return _selectedProduct.Price + sizeExtra + toppingExtra;
        }
    }

    private void AddSelectedToCart()
    {
        if (_selectedProduct is null)
        {
            return;
        }

        var toppings = new List<string>();
        if (_addPearl) toppings.Add("珍珠");
        if (_addCoconut) toppings.Add("椰果");

        _cart.Add(new OrderLine(
            _selectedProduct.Name,
            _selectedSize,
            _selectedSugar,
            _selectedIce,
            toppings,
            CurrentSelectedPrice,
            1,
            _note));

        _status = $"已加入：{_selectedProduct.Name}";
        _selectedProduct = null;
        _note = string.Empty;
    }

    private void IncreaseQuantity(OrderLine line) => line.Quantity++;

    private void DecreaseQuantity(OrderLine line)
    {
        line.Quantity--;
        if (line.Quantity <= 0)
        {
            _cart.Remove(line);
        }
    }

    private void ClearCart()
    {
        _cart.Clear();
        _status = "已清空訂單";
    }

    private async Task SaveDraftAsync()
    {
        if (_cart.Count == 0)
        {
            _status = "購物車是空的，無法暫存。";
            return;
        }

        await PersistOrderAsync("Draft");
        _status = $"已暫存訂單：{_currentOrderCode}";
    }

    private async Task ResumeDraftAsync(CompletedOrder order)
    {
        var entity = await Db.Orders
            .Include(x => x.Items)
            .FirstAsync(x => x.Id == order.Id);

        _cart.Clear();
        foreach (var item in entity.Items)
        {
            _cart.Add(new OrderLine(
                item.ProductName,
                item.Size,
                item.Sugar,
                item.Ice,
                (item.Toppings ?? "無加料") == "無加料"
                    ? []
                    : item.Toppings!.Split('、', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList(),
                item.UnitPrice,
                item.Quantity,
                item.Note ?? string.Empty));
        }

        _currentOrderCode = entity.OrderCode;
        _selectedPayment = entity.PaymentMethod;
        _customerPhone = entity.CustomerPhone ?? string.Empty;
        _selectedOrderType = entity.OrderType == "Delivery" ? "外送" : "外帶";
        _editingDraftOrderId = entity.Id;
        _status = $"已載回暫存訂單：{entity.OrderCode}";
    }

    private void CheckoutAsync()
    {
        if (_cart.Count == 0)
        {
            _status = "購物車是空的，無法結帳。";
            return;
        }

        _showCheckoutConfirm = true;
    }

    private async Task ConfirmCheckoutAsync()
    {
        await PersistOrderAsync("Completed");
        _showCheckoutConfirm = false;
        _status = $"結帳完成：{_currentOrderCode} / {_selectedPayment} / {TotalAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))}";
    }

    private void CancelCheckout()
    {
        _showCheckoutConfirm = false;
        _status = "已取消結帳確認。";
    }

    private async Task PersistOrderAsync(string status)
    {
        var summary = string.Join("、", _cart.Select(x => $"{x.Name}x{x.Quantity}"));

        if (!string.IsNullOrWhiteSpace(_customerPhone))
        {
            var customer = await Db.Customers.FirstOrDefaultAsync(x => x.Phone == _customerPhone);
            if (customer is null)
            {
                Db.Customers.Add(new CustomerEntity { Phone = _customerPhone, DisplayName = _customerPhone, LoyaltyPoints = 0 });
            }
        }

        var promotion = ActivePromotion;
        var promotionName = PromotionDiscountAmount > 0 ? promotion?.Name : null;

        OrderEntity order;
        if (_editingDraftOrderId.HasValue)
        {
            order = await Db.Orders.Include(x => x.Items).FirstAsync(x => x.Id == _editingDraftOrderId.Value);
            order.PaymentMethod = _selectedPayment;
            order.OrderType = SelectedOrderTypeCode;
            order.PromotionName = promotionName;
            order.PromotionDiscountAmount = PromotionDiscountAmount;
            order.CustomerPhone = _customerPhone;
            order.TotalAmount = TotalAmount;
            order.OrderSummary = summary;
            order.Status = status;
            order.CreatedAt = DateTime.UtcNow;
            Db.OrderItems.RemoveRange(order.Items);
            order.Items.Clear();
        }
        else
        {
            order = new OrderEntity
            {
                OrderCode = _currentOrderCode,
                PaymentMethod = _selectedPayment,
                OrderType = SelectedOrderTypeCode,
                PromotionName = promotionName,
                PromotionDiscountAmount = PromotionDiscountAmount,
                CustomerPhone = _customerPhone,
                TotalAmount = TotalAmount,
                CreatedAt = DateTime.UtcNow,
                OrderSummary = summary,
                Status = status
            };
            Db.Orders.Add(order);
        }

        foreach (var line in _cart)
        {
            order.Items.Add(new OrderItemEntity
            {
                ProductName = line.Name,
                Size = line.Size,
                Sugar = line.Sugar,
                Ice = line.Ice,
                Toppings = line.ToppingLabel,
                Note = line.Note,
                Quantity = line.Quantity,
                UnitPrice = line.UnitPrice
            });
        }

        await Db.SaveChangesAsync();

        _editingDraftOrderId = null;
        _cart.Clear();
        _customerPhone = string.Empty;
        _note = string.Empty;
        _discountAmount = 0;
        _receivedAmount = 0;
        await LoadRecentOrdersAsync();
    }

    private async Task VoidOrderAsync(CompletedOrder order)
    {
        var entity = await Db.Orders.FirstAsync(x => x.Id == order.Id);
        entity.Status = "Voided";
        await Db.SaveChangesAsync();
        await LoadRecentOrdersAsync();
        _status = $"已作廢訂單：{order.OrderCode}";
    }

    private void PrintKitchenTicket() => _cart.Count == 0
        ? _status = "目前沒有可列印的訂單。"
        : _status = $"已模擬送出廚房單：{_currentOrderCode}";

    private void PrintSticker() => _cart.Count == 0
        ? _status = "目前沒有可列印的杯貼。"
        : _status = $"已模擬送出杯貼列印：{_currentOrderCode}";

    private void PrintReceipt() => _cart.Count == 0
        ? _status = "目前沒有可列印的小白單。"
        : _status = $"已模擬列印收據：{_currentOrderCode}";

    private void OpenCashDrawer() => _status = "已模擬開啟錢櫃。";

    private decimal GrossAmount => _cart.Sum(x => x.Subtotal);
    private int TotalQuantity => _cart.Sum(x => x.Quantity);
    private bool PromotionApplicable => ActivePromotion is not null;
    private string PromotionDisplayName => ActivePromotion?.Name ?? "目前無活動";
    private int PromotionFreeCupCount => CalculatePromotionFreeCupCount();
    private decimal PromotionDiscountAmount => CalculatePromotionDiscount();
    private decimal TotalAmount => Math.Max(0, GrossAmount - PromotionDiscountAmount - _discountAmount);
    private decimal ChangeAmount => Math.Max(0, _receivedAmount - TotalAmount);

    private int CalculatePromotionFreeCupCount()
    {
        var promotion = ActivePromotion;
        if (promotion is null || _cart.Count == 0)
        {
            return 0;
        }

        var groupSize = promotion.BuyQuantity + promotion.FreeQuantity;
        if (groupSize <= 0)
        {
            return 0;
        }

        return (TotalQuantity / groupSize) * promotion.FreeQuantity;
    }

    private decimal CalculatePromotionDiscount()
    {
        var promotion = ActivePromotion;
        if (promotion is null || PromotionFreeCupCount <= 0 || _cart.Count == 0)
        {
            return 0m;
        }

        var allCupPrices = _cart
            .SelectMany(x => Enumerable.Repeat(x.UnitPrice, x.Quantity))
            .OrderByDescending(x => x)
            .ToList();

        var groupSize = promotion.BuyQuantity + promotion.FreeQuantity;
        decimal discount = 0m;

        for (var freeIndex = 0; freeIndex < PromotionFreeCupCount; freeIndex++)
        {
            var targetIndex = ((freeIndex / promotion.FreeQuantity) * groupSize) + promotion.BuyQuantity + (freeIndex % promotion.FreeQuantity);
            if (targetIndex < allCupPrices.Count)
            {
                discount += allCupPrices[targetIndex];
            }
        }

        return discount;
    }

    private sealed record ProductCategoryViewModel(int Id, string Name, List<ProductViewModel> Products);
    private sealed record ProductViewModel(int Id, string Name, decimal Price, List<string> Sizes, bool IsTea);
    private sealed record PromotionViewModel(int Id, string Name, string OrderTypeScope, int BuyQuantity, int FreeQuantity, bool IsEnabled);
    private sealed record CompletedOrder(int Id, string OrderCode, DateTime CreatedAt, string Payment, string Summary, decimal Amount, string Status, string OrderType, string? PromotionName, decimal PromotionDiscountAmount);

    private sealed class OrderLine(string name, string size, string sugar, string ice, List<string> toppings, decimal unitPrice, int quantity, string note)
    {
        public string Name { get; } = name;
        public string Size { get; } = size;
        public string Sugar { get; } = sugar;
        public string Ice { get; } = ice;
        public List<string> Toppings { get; } = toppings;
        public decimal UnitPrice { get; } = unitPrice;
        public int Quantity { get; set; } = quantity;
        public string Note { get; } = note;
        public decimal Subtotal => UnitPrice * Quantity;
        public string ToppingLabel => Toppings.Count == 0 ? "無加料" : string.Join("、", Toppings);
    }
}

<div class="pos-shell compact-shell tighter-shell">
    <div class="top-bar simple-top-bar">
        <div>
            <div class="eyebrow">Beverage Counter Demo</div>
            <h1>G8 POS 櫃台 Demo</h1>
        </div>
    </div>

    <div class="summary-strip slim-summary">
        <div class="summary-card accent-orange"><span>杯數</span><strong>@TotalQuantity</strong></div>
        <div class="summary-card accent-green"><span>總金額</span><strong>@TotalAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
        <div class="summary-card accent-blue"><span>活動優惠</span><strong>@(PromotionApplicable ? (PromotionFreeCupCount > 0 ? $"{PromotionDisplayName} -{PromotionDiscountAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))}" : $"{PromotionDisplayName} 已啟用") : "目前不適用")</strong></div>
    </div>

    <div class="pos-grid full-height-grid">
        <section class="panel categories-panel">
            <div class="section-header">
                <h2>商品區</h2>
                <input class="search-box" @bind="_searchText" @bind:event="oninput" placeholder="搜尋飲料名稱" />
            </div>
            <div class="category-list compact-list">
                @foreach (var category in _categories)
                {
                    <button class="category-chip @(category == _selectedCategory ? "active" : null)" @onclick="() => SelectCategory(category)">@category.Name</button>
                }
            </div>
            <div class="product-grid dense-grid">
                @foreach (var product in FilteredProducts)
                {
                    <button class="product-card @(product == _selectedProduct ? "active" : null)" @onclick="() => SelectProduct(product)">
                        <span>@product.Name</span>
                        <small>@string.Join("/", product.Sizes) / @(product.IsTea ? "茶飲" : "奶系")</small>
                        <strong>@product.Price.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                    </button>
                }
            </div>
        </section>

        <section class="panel middle-panel">
            <div class="stack-section">
                <h2>客製設定</h2>
                @if (_selectedProduct is null)
                {
                    <div class="empty-state small-fill">先選一杯飲料，再調整糖冰、尺寸與加料。</div>
                }
                else
                {
                    <div class="selected-product compact-card">
                        <div>
                            <div class="eyebrow">已選商品</div>
                            <h3>@_selectedProduct.Name</h3>
                        </div>
                        <div class="selected-price">@CurrentSelectedPrice.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</div>
                    </div>

                    <label>尺寸</label>
                    <div class="option-chip-group compact-list">
                        @foreach (var size in _selectedProduct.Sizes)
                        {
                            <button type="button" class="option-chip @(size == _selectedSize ? "active" : null)" @onclick="() => _selectedSize = size">@size</button>
                        }
                    </div>

                    <label>糖度</label>
                    <div class="option-chip-group compact-list">
                        @foreach (var sugar in _sugarOptions)
                        {
                            <button type="button" class="option-chip @(sugar == _selectedSugar ? "active" : null)" @onclick="() => _selectedSugar = sugar">@sugar</button>
                        }
                    </div>

                    <label>冰量</label>
                    <div class="option-chip-group compact-list">
                        @foreach (var ice in _iceOptions)
                        {
                            <button type="button" class="option-chip @(ice == _selectedIce ? "active" : null)" @onclick="() => _selectedIce = ice">@ice</button>
                        }
                    </div>

                    <label>加料</label>
                    <div class="topping-list compact-list">
                        <label><input type="checkbox" @bind="_addPearl" /> 珍珠 (+10)</label>
                        <label><input type="checkbox" @bind="_addCoconut" /> 椰果 (+10)</label>
                    </div>

                    <label>備註</label>
                    <input class="search-box full-input" @bind="_note" placeholder="例如：少冰去糖、先做" />

                    <div class="action-grid single-action-grid">
                        <button class="primary-action large-action" @onclick="AddSelectedToCart">加入訂單</button>
                    </div>
                }
            </div>

            <div class="stack-section recent-orders-box no-top-border">
                <div class="section-header compact"><h2>最近完成訂單</h2></div>
                @if (_recentOrders.Count == 0)
                {
                    <div class="empty-state small">還沒有完成訂單。</div>
                }
                else
                {
                    <div class="recent-orders-list compact-scroll">
                        @foreach (var order in _recentOrders)
                        {
                            <div class="recent-order-item">
                                <div>
                                    <strong>@order.OrderCode</strong>
                                    <div class="meta">@order.CreatedAt:HH:mm / @order.Payment / @order.Status</div>
                                    <div class="meta">@order.OrderType / @(string.IsNullOrWhiteSpace(order.PromotionName) ? "無活動" : $"{order.PromotionName} -{order.PromotionDiscountAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))}")</div>
                                    <div class="meta">@order.Summary</div>
                                </div>
                                <div class="admin-action-row">
                                    <strong>@order.Amount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                                    @if (order.Status == "Draft")
                                    {
                                        <button class="ghost-action" @onclick="() => ResumeDraftAsync(order)">續編</button>
                                    }
                                    @if (order.Status != "Voided")
                                    {
                                        <button class="ghost-action" @onclick="() => VoidOrderAsync(order)">作廢</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="panel cart-panel">
            <div class="cart-header">
                <div>
                    <h2>當前訂單</h2>
                    <div class="meta">@(_editingDraftOrderId.HasValue ? "正在續編暫存單" : "點餐中")</div>
                </div>
                <button class="ghost-action" @onclick="ClearCart">清空</button>
            </div>

            <div class="customer-block">
                <div class="payment-row">
                    @foreach (var orderType in _orderTypeOptions)
                    {
                        <button class="option-chip compact @(orderType == _selectedOrderType ? "active" : null)" @onclick="() => _selectedOrderType = orderType">@orderType</button>
                    }
                </div>
                <div class="promotion-toggle-card">
                    <div>
                        <strong>@PromotionDisplayName</strong>
                        <div class="meta">@(PromotionApplicable ? "目前會依訂單類型自動套用。" : "這個訂單類型目前沒有啟用活動。")</div>
                    </div>
                    <div class="meta">@(PromotionApplicable ? $"買 {ActivePromotion!.BuyQuantity} 送 {ActivePromotion.FreeQuantity}" : "無活動")</div>
                </div>
                <input class="search-box full-input" @bind="_customerPhone" placeholder="會員手機 / 電話" />
                <div class="payment-row">
                    @foreach (var payment in _paymentOptions)
                    {
                        <button class="option-chip compact @(payment == _selectedPayment ? "active" : null)" @onclick="() => _selectedPayment = payment">@payment</button>
                    }
                </div>
                <div class="payment-fields-grid">
                    <input class="admin-input" type="number" step="1" @bind="_discountAmount" placeholder="折扣金額" />
                    <input class="admin-input" type="number" step="1" @bind="_receivedAmount" placeholder="實收金額" />
                </div>
            </div>

            @if (_cart.Count == 0)
            {
                <div class="empty-state order-scroll">購物車目前是空的。</div>
            }
            else
            {
                <div class="cart-list order-scroll">
                    @foreach (var line in _cart)
                    {
                        <div class="cart-line">
                            <div>
                                <strong>@line.Name</strong>
                                <div class="meta">@line.Size / @line.Sugar / @line.Ice / @line.ToppingLabel</div>
                                @if (!string.IsNullOrWhiteSpace(line.Note))
                                {
                                    <div class="meta">備註：@line.Note</div>
                                }
                            </div>
                            <div class="line-actions">
                                <button @onclick="() => DecreaseQuantity(line)">-</button>
                                <span>@line.Quantity</span>
                                <button @onclick="() => IncreaseQuantity(line)">+</button>
                            </div>
                            <strong>@line.Subtotal.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong>
                        </div>
                    }
                </div>
            }

            <div class="checkout-box pinned-footer">
                <div class="checkout-summary">
                    <div class="total-row"><span>訂單類型</span><strong>@_selectedOrderType</strong></div>
                    <div class="total-row"><span>總杯數</span><strong>@TotalQuantity</strong></div>
                    <div class="total-row"><span>原始金額</span><strong>@GrossAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>@PromotionDisplayName</span><strong>@(PromotionApplicable ? (PromotionFreeCupCount > 0 ? $"-{PromotionDiscountAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))}" : "已啟用，未達門檻") : "不適用")</strong></div>
                    <div class="total-row"><span>手動折扣</span><strong>@_discountAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>付款方式</span><strong>@_selectedPayment</strong></div>
                    <div class="total-row"><span>實收金額</span><strong>@_receivedAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>找零</span><strong>@ChangeAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row emphasis"><span>應收金額</span><strong>@TotalAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                </div>
                <button class="secondary-action" @onclick="SaveDraftAsync">@(_editingDraftOrderId.HasValue ? "更新暫存單" : "暫存訂單")</button>
                <button class="checkout-action" @onclick="CheckoutAsync">@(_editingDraftOrderId.HasValue ? "完成續編結帳" : "完成結帳")</button>
            </div>
        </section>
    </div>

    @if (_showCheckoutConfirm)
    {
        <div class="modal-backdrop">
            <div class="checkout-modal">
                <div class="section-header compact">
                    <h2>結帳確認</h2>
                    <button class="ghost-action" @onclick="CancelCheckout">關閉</button>
                </div>

                <div class="checkout-summary modal-summary">
                    <div class="total-row"><span>訂單類型</span><strong>@_selectedOrderType</strong></div>
                    <div class="total-row"><span>應收金額</span><strong>@TotalAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>@PromotionDisplayName</span><strong>@(PromotionApplicable ? (PromotionFreeCupCount > 0 ? $"已折抵 {PromotionDiscountAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))}" : "已啟用，未達門檻") : "不適用")</strong></div>
                    <div class="total-row"><span>實收金額</span><strong>@_receivedAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>找零</span><strong>@ChangeAmount.ToString("C0", CultureInfo.GetCultureInfo("zh-TW"))</strong></div>
                    <div class="total-row"><span>付款方式</span><strong>@_selectedPayment</strong></div>
                </div>

                <div class="action-grid modal-action-grid">
                    <button class="secondary-action" @onclick="PrintKitchenTicket">印廚房單</button>
                    <button class="secondary-action" @onclick="PrintSticker">印杯貼</button>
                    <button class="secondary-action" @onclick="PrintReceipt">印收據</button>
                    <button class="secondary-action" @onclick="OpenCashDrawer">開錢櫃</button>
                    <button class="checkout-action" @onclick="ConfirmCheckoutAsync">確認完成結帳</button>
                </div>
            </div>
        </div>
    }
</div>
