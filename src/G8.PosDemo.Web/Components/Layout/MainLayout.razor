@inherits LayoutComponentBase

@code {
    private bool _sidebarExpanded = false;

    private string SidebarStateClass => _sidebarExpanded ? "sidebar-expanded" : "sidebar-collapsed";

    private void ToggleSidebar()
    {
        _sidebarExpanded = !_sidebarExpanded;
    }
}

<div class="layout-shell @SidebarStateClass">
    <aside class="app-sidebar">
        <div class="sidebar-header">
            <button class="sidebar-toggle-btn" type="button" @onclick="ToggleSidebar">
                <span class="toggle-icon">☰</span>
                @if (_sidebarExpanded)
                {
                    <span>收合選單</span>
                }
                else
                {
                    <span>展開</span>
                }
            </button>
        </div>

        <div class="sidebar-body">
            <NavMenu Expanded="_sidebarExpanded" />
        </div>
    </aside>

    <main class="layout-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
